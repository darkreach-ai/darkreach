#!/usr/bin/env bash
# Conventional commit message validation hook.
#
# Enforces: <type>(<scope>): <description>
# Types:    feat, fix, refactor, docs, test, chore, perf, ci, build, style
# Scopes:   engine, frontend, server, dashboard, ops, db, database, docs,
#           research, ai, agent, network, test, ci
#
# Install: ln -sf ../../scripts/commit-msg .git/hooks/commit-msg

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

# Allow merge commits and reverts
if echo "$COMMIT_MSG" | grep -qE '^(Merge|Revert) '; then
    exit 0
fi

# Conventional commit pattern: type(optional-scope): description
PATTERN='^(feat|fix|refactor|docs|test|chore|perf|ci|build|style)(\([a-z0-9_-]+\))?: .{1,72}$'

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo -e "${RED}Invalid commit message:${NC}"
    echo "  $COMMIT_MSG"
    echo ""
    echo -e "${YELLOW}Expected format:${NC}"
    echo "  <type>(<scope>): <description>"
    echo ""
    echo "  Types:  feat, fix, refactor, docs, test, chore, perf, ci, build, style"
    echo "  Scopes: engine, frontend, server, dashboard, ops, db, database,"
    echo "          docs, research, ai, agent, network, test, ci"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  feat(engine): add Montgomery multiplication for sieve"
    echo "  fix(dashboard): correct WebSocket reconnect logic"
    echo "  docs: update roadmap"
    echo "  chore: bump dependencies"
    echo ""
    exit 1
fi

exit 0
